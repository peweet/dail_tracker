    <debateBody><debateSection name="writtenAnswer" eId="dbsect_471">
          <heading>Social Insurance<recordedTime time="2026-04-21T00:30:00+01:00"/></heading>
          <question by="#JohnPaulOShea" to="#Social" eId="pq_609">
            <p eId="para_5271">609. <b>Deputy John Paul O'Shea</b> asked the <b>Minister for Social Protection</b> the number of workers subject to the lower rate of Employer PRSI of 9%; the number of workers subject to the higher rate of Employer PRSI of 11.25%, in tabular form; and if he will make a statement on the matter. [28303/26]</p>
          </question>
          <speech by="#DaraCalleary" as="#Minister_for_Social_Protection" eId="spk_856">
            <from>Minister for Social Protection<recordedTime time="2026-04-21T00:30:00+01:00"/></from>
            <p eId="para_5272">The information requested by the Deputy is contained in the table below.</p>
            <table>
              <tr>
                <td>
                  <p eId="para_5273">PRSI Rate</p>
                </td>
                <td>
                  <p eId="para_5274">Estimated Number of Employees (2026)</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p eId="para_5275">11.25%</p>
                </td>
                <td>
                  <p eId="para_5276">1,972,000</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p eId="para_5277">9%</p>
                </td>
                <td>
                  <p eId="para_5278">889,000</p>
                </td>
              </tr>
            </table>
            <p eId="para_5279">
						</p>
          </speech>
