# === Curated reference data — hand-authored, NOT regenerable — MUST be tracked ===
# Overrides the blanket *.csv / *.json rules above (last match wins) so these
# source-of-truth lookup tables (si_department_aliases, loan_book_fund_aliases,
# nace_v2_sections) are committed, not silently swallowed. Keep this block last.
!data/_meta/
!data/_meta/*.csv
!data/_meta/*.json
# public-body procurement publisher seed registry (Phase-1 of the semistate plan) —
# a subdir, so the *.csv negation above (top-level only) does not reach it.
!data/_meta/procurement_publishers/
!data/_meta/procurement_publishers/*.csv

# basedpyright baseline — snapshots known/false-positive type findings so CI
# fails only on NEW errors. Must be tracked or CI re-flags the baselined items.
# Overrides the blanket *.json rule above (last match wins).
!.basedpyright/
!.basedpyright/baseline.json

# Oireachtas API JSON schemas — fetch-time envelope validation (validate_if_known)
# AND the test/services/test_api_schemas.py suite both load these at runtime. The
# blanket *.json rule above swallows them, so a fresh clone / CI runner would hit
# FileNotFoundError on the first validated fetch and fail the schema tests. Track
# them explicitly (last match wins).
!services/schemas/
!services/schemas/*.json

# === Runtime data for the deployed Streamlit app — committed deliberately (~16 MB) ===
# Streamlit Cloud boots from a fresh git clone with no ETL, so the gold parquet + the
# handful of silver CSVs that utility/ + sql_views/ read at runtime MUST be tracked.
# The blanket *.parquet / *.csv / data/gold/ rules above swallow them; re-include
# exactly the runtime set here (last match wins). Parent dirs are re-included first —
# git cannot un-ignore a file whose parent directory is excluded. Everything else in
# these trees (gold/csv, intermediate silver) stays ignored via the type rules above.
!data/gold/
!data/gold/parquet/
!data/gold/parquet/*.parquet
!data/silver/aggregated_td_tables.csv
!data/silver/flattened_members.csv
!data/silver/flattened_seanad_members.csv
!data/silver/seanad_aggregated_tables.csv
!data/silver/lobbying/
!data/silver/lobbying/client_company_returns_detail.csv
# amalgamated AFS silver fact (afs_amalgamated_extract.py) — read by the afs_*.sql views
!data/silver/parquet/
!data/silver/parquet/afs_amalgamated_divisions.parquet
# LA Purchase-Orders/Payments-over-€20k silver fact (procurement_la_payments_extract.py)
!data/silver/parquet/la_payments_fact.parquet
# per-LA AFS revenue fact (la_afs_extract.py) — read by tests + future gold views/UI; commit
# so it survives machine failure / is Cloud-readable even if a council removes its source PDF
!data/silver/parquet/la_afs_divisions.parquet
# Silver facts the deployed app's runtime SQL views read DIRECTLY and query live in
# DuckDB (registered via utility/data_access/_sql_registry.py + member_overview_data.py).
# Without these a fresh Cloud clone hard-crashes the Lobbying / Interests / Committees
# pages (swallow_errors=False) and leaves Home / Legislation / Attendance half-empty.
# ~85 MB total, all zstd. Parent dirs re-included first (git can't un-ignore a file
# under an excluded dir). Keep in sync with the runtime view scan over sql_views/.
!data/silver/ministerial_tenure.parquet
!data/silver/charities/
!data/silver/charities/annual_reports.parquet
!data/silver/charities/charity_resolved.parquet
!data/silver/committees/
!data/silver/committees/committee_assignments.parquet
!data/silver/committees/office_holders.parquet
!data/silver/cro/
!data/silver/cro/companies.parquet
!data/silver/cro/financial_statements.parquet
!data/silver/lobbying/parquet/
!data/silver/lobbying/parquet/politician_returns_detail.parquet
!data/silver/lobbying/parquet/returns_master.parquet
!data/silver/lobbying/parquet/revolving_door_returns_detail.parquet
!data/silver/parquet/bill_amendments.parquet
!data/silver/parquet/dail_member_interests_combined.parquet
!data/silver/parquet/debate_listings.parquet
!data/silver/parquet/debates.parquet
!data/silver/parquet/flattened_members.parquet
!data/silver/parquet/flattened_seanad_members.parquet
!data/silver/parquet/lobbying_return_documents.parquet
!data/silver/parquet/member_external_links.parquet
!data/silver/parquet/questions.parquet
!data/silver/parquet/related_docs.parquet
!data/silver/parquet/seanad_member_interests_combined.parquet
!data/silver/parquet/sponsors.parquet
!data/silver/parquet/stages.parquet
!data/silver/parquet/versions.parquet
# SIPO GE2024 silver facts + per-party intermediates + OCR checkpoint cache
# (extractors/sipo_*; all regenerable). The OCR cache enables --parse-only without
# re-OCR. Gold (data/gold/parquet/sipo_donations.parquet, sipo_expenses_fact.parquet)
# is the committed serving copy the SQL views read.
data/silver/sipo/

# === Legal Diary raw daily DOCX archive — NEVER commit ===
# pdf_infra/legal_diary_poller.py archives the Courts Service daily diary under
# data/bronze/legal_diary/<date>.docx. The raw file names PRIVATE parties (minors,
# wards, criminal defendants) in full — only the ANONYMISED gold parquet
# (judicial_legal_diary_cases.parquet, initials only) may ever leave this machine.
# No *.docx rule exists above, so this dir would otherwise be committable. Guard it.
data/bronze/legal_diary/

# === Member avatars (Wikidata portraits + manifest) — committed deliberately ===
# wiki_data.py downloads CC-licensed TD + Senator portraits into avatar/wikidata/.
# Streamlit Cloud boots from a fresh git clone with no ETL, so utility/ui/avatars.py
# has nothing to read unless these ship in the repo. The blanket *.jpg / *.json
# rules above swallow them; re-include the portrait set here (last match wins).
# Parent dir re-included first — git cannot un-ignore a file under an excluded dir.
!avatar/wikidata/
!avatar/wikidata/*.jpg
!avatar/wikidata/*.jpeg
!avatar/wikidata/*.png
!avatar/wikidata/*.webp
!avatar/wikidata/manifest.json

# === SQL-view test fixtures — committed deliberately ===
# test/fixtures/sql_views/_generate.py writes small synthetic parquets that let
# test/test_sql_views.py run the view-contract tests in CI without any pipeline
# output. The blanket *.parquet rule above swallows them; re-include the whole
# fixture tree (last match wins). No parent dir is ignored, so file-level
# negation is enough.
!test/fixtures/sql_views/**/*.parquet

# === AFS golden fixture — committed deliberately (test/test_afs_amalgamated.py) ===
# The 64-row amalgamated-AFS golden parquet lets the data-integrity tests run in CI
# without re-downloading the gov.ie PDFs. Page-text fixture (.txt) isn't ignored.
!test/fixtures/afs/*.parquet
# LA-payments golden slice (test/fixtures/la_payments/_generate.py) for the Tier-3 invariants
!test/fixtures/la_payments/*.parquet
# per-LA AFS golden fact (test/fixtures/la_afs/_generate.py) for test/test_la_afs.py invariants
!test/fixtures/la_afs/*.parquet
